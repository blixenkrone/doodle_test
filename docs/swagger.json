{
    "schemes": [
        "http"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Doodle API",
        "title": "API",
        "contact": {
            "name": "test"
        },
        "version": "1.0"
    },
    "basePath": "/",
    "paths": {
        "/health": {
            "get": {
                "description": "Probe verifying that the container has started.",
                "tags": [
                    "probe"
                ],
                "summary": "Container Liveness Probe.",
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "500": {
                        "description": "Internal Server Error"
                    }
                }
            }
        },
        "/ready": {
            "get": {
                "description": "Probe verifying that the app is fully ready to serve requests.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "probe"
                ],
                "summary": "Container Readiness Probe.",
                "responses": {
                    "200": {
                        "description": "OK"
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/sdk_http.HTTPError"
                        }
                    }
                }
            }
        },
        "/users": {
            "post": {
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "onboarding"
                ],
                "summary": "Create an User (tenant)",
                "parameters": [
                    {
                        "description": "request body",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/internal_onboarding.CreateUserRequest"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/internal_onboarding.CreateUserResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/github_com_blixenkrone_sdk_http.HTTPError"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/github_com_blixenkrone_sdk_http.HTTPError"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "github_com_blixenkrone_sdk_http.HTTPError": {
            "description": "Error response",
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 400
                },
                "message": {
                    "type": "string",
                    "example": "bad input"
                }
            }
        },
        "internal_onboarding.CreateUserRequest": {
            "type": "object",
            "properties": {
                "slug": {
                    "type": "string"
                }
            }
        },
        "internal_onboarding.CreateUserResponse": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string"
                }
            }
        },
        "sdk_http.HTTPError": {
            "description": "Error response",
            "type": "object",
            "properties": {
                "code": {
                    "type": "integer",
                    "example": 400
                },
                "message": {
                    "type": "string",
                    "example": "bad input"
                }
            }
        }
    }
